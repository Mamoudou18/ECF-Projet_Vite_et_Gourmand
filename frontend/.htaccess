RewriteEngine On

# D'abord : ne JAMAIS réécrire les assets statiques (peu importe s'ils existent)
RewriteRule \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ - [L]

# Ensuite : si fichier/dossier existe, le servir directement
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Tout le reste vers router.php
RewriteRule ^ router.php [QSA,L]
