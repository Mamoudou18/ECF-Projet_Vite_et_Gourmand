<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # API routes passent directement
    RewriteRule ^api/ - [L]
    
    # Fichiers/dossiers existants
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]
    
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Tout le reste va à index.php
    RewriteRule ^ index.php [L]
</IfModule>
